diff --git a/keystone/tests/unit/test_oauth2_proxy_headers.py b/keystone/tests/unit/test_oauth2_proxy_headers.py
new file mode 100644
index 0000000..4d184dc
--- /dev/null
+++ b/keystone/tests/unit/test_oauth2_proxy_headers.py
@@ -0,0 +1,139 @@
+# Copyright (c) 2026 Wind River Systems, Inc.
+#
+# SPDX-License-Identifier: Apache-2.0
+#
+import base64
+import json
+import unittest
+from unittest import mock
+
+from keystone.middleware import oauth2_proxy_headers
+
+
+class TestOAuth2ProxyHeadersMiddleware(unittest.TestCase):
+    """Tests for OAuth2ProxyHeadersMiddleware."""
+
+    def setUp(self):
+        self.app = mock.Mock(return_value=['response'])
+        self.middleware = oauth2_proxy_headers.OAuth2ProxyHeadersMiddleware(
+            self.app)
+        self.start_response = mock.Mock()
+
+    def _make_token(self, claims):
+        """Create a fake JWT token (unsigned)."""
+        header = base64.urlsafe_b64encode(
+            json.dumps({"alg": "none"}).encode()).rstrip(b'=')
+        payload = base64.urlsafe_b64encode(
+            json.dumps(claims).encode()).rstrip(b'=')
+        return (header + b'.' + payload + b'.').decode()
+
+    def _make_environ(self, path='/v3/auth/OS-FEDERATION/identity_providers'
+                      '/dex/protocols/openid/websso', **kwargs):
+        """Create a WSGI environ dict."""
+        environ = {'PATH_INFO': path}
+        environ.update(kwargs)
+        return environ
+
+    def test_non_federation_path_passes_through(self):
+        """Middleware does nothing for non-federation paths."""
+        environ = self._make_environ(path='/v3/auth/tokens')
+        self.middleware(environ, self.start_response)
+        self.assertNotIn('REMOTE_USER', environ)
+        self.assertNotIn('HTTP_OIDC_ISS', environ)
+        self.app.assert_called_once()
+
+    def test_jwt_claims_mapped_to_env_vars(self):
+        """JWT claims are correctly mapped to HTTP_OIDC_* vars."""
+        token = self._make_token({
+            'iss': 'https://dex.example.com',
+            'sub': 'user123',
+            'email': 'user@example.com',
+            'name': 'Test User',
+            'preferred_username': 'testuser',
+        })
+        environ = self._make_environ(
+            HTTP_X_FORWARDED_ACCESS_TOKEN=token)
+        self.middleware(environ, self.start_response)
+        self.assertEqual(environ['HTTP_OIDC_ISS'],
+                         'https://dex.example.com')
+        self.assertEqual(environ['HTTP_OIDC_SUB'], 'user123')
+        self.assertEqual(environ['HTTP_OIDC_EMAIL'],
+                         'user@example.com')
+        self.assertEqual(environ['HTTP_OIDC_NAME'], 'Test User')
+        self.assertEqual(environ['HTTP_OIDC_PREFERRED_USERNAME'],
+                         'testuser')
+
+    def test_remote_user_from_forwarded_user(self):
+        """REMOTE_USER set from X-Forwarded-User header."""
+        token = self._make_token({'iss': 'https://dex.example.com',
+                                  'email': 'user@example.com'})
+        environ = self._make_environ(
+            HTTP_X_FORWARDED_ACCESS_TOKEN=token,
+            HTTP_X_FORWARDED_USER='operator')
+        self.middleware(environ, self.start_response)
+        self.assertEqual(environ['REMOTE_USER'], 'operator')
+
+    def test_remote_user_fallback_to_email(self):
+        """REMOTE_USER falls back to email when no X-Forwarded-User."""
+        token = self._make_token({'iss': 'https://dex.example.com',
+                                  'email': 'user@example.com'})
+        environ = self._make_environ(
+            HTTP_X_FORWARDED_ACCESS_TOKEN=token)
+        self.middleware(environ, self.start_response)
+        self.assertEqual(environ['REMOTE_USER'],
+                         'user@example.com')
+
+    def test_remote_user_fallback_to_sub(self):
+        """REMOTE_USER falls back to sub when no email."""
+        token = self._make_token({'iss': 'https://dex.example.com',
+                                  'sub': 'user123'})
+        environ = self._make_environ(
+            HTTP_X_FORWARDED_ACCESS_TOKEN=token)
+        self.middleware(environ, self.start_response)
+        self.assertEqual(environ['REMOTE_USER'], 'user123')
+
+    def test_bearer_token_from_authorization_header(self):
+        """Token extracted from Authorization: Bearer header."""
+        token = self._make_token({
+            'iss': 'https://dex.example.com',
+            'email': 'user@example.com'})
+        environ = self._make_environ(
+            HTTP_AUTHORIZATION='Bearer ' + token)
+        self.middleware(environ, self.start_response)
+        self.assertEqual(environ['HTTP_OIDC_ISS'],
+                         'https://dex.example.com')
+
+    def test_no_token_sets_no_vars(self):
+        """No env vars set when no token is present."""
+        environ = self._make_environ()
+        self.middleware(environ, self.start_response)
+        self.assertNotIn('HTTP_OIDC_ISS', environ)
+        self.assertNotIn('REMOTE_USER', environ)
+
+    def test_invalid_token_handled_gracefully(self):
+        """Invalid JWT doesn't crash the middleware."""
+        environ = self._make_environ(
+            HTTP_X_FORWARDED_ACCESS_TOKEN='not.a.valid.jwt')
+        self.middleware(environ, self.start_response)
+        self.assertNotIn('HTTP_OIDC_ISS', environ)
+        self.app.assert_called_once()
+
+    def test_missing_claims_partially_mapped(self):
+        """Only present claims are mapped."""
+        token = self._make_token({'iss': 'https://dex.example.com'})
+        environ = self._make_environ(
+            HTTP_X_FORWARDED_ACCESS_TOKEN=token)
+        self.middleware(environ, self.start_response)
+        self.assertEqual(environ['HTTP_OIDC_ISS'],
+                         'https://dex.example.com')
+        self.assertNotIn('HTTP_OIDC_EMAIL', environ)
+        self.assertNotIn('HTTP_OIDC_SUB', environ)
+
+    def test_filter_factory(self):
+        """filter_factory returns a working middleware."""
+        factory = oauth2_proxy_headers.filter_factory({})
+        app = mock.Mock()
+        middleware = factory(app)
+        self.assertIsInstance(
+            middleware,
+            oauth2_proxy_headers.OAuth2ProxyHeadersMiddleware)
