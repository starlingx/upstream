diff --git a/keystone/middleware/oauth2_proxy_headers.py b/keystone/middleware/oauth2_proxy_headers.py
new file mode 100644
index 0000000..78b4602
--- /dev/null
+++ b/keystone/middleware/oauth2_proxy_headers.py
@@ -0,0 +1,96 @@
+# Copyright (c) 2026 Wind River Systems, Inc.
+#
+# SPDX-License-Identifier: Apache-2.0
+#
+import logging
+
+import jwt
+
+LOG = logging.getLogger(__name__)
+
+
+class OAuth2ProxyHeadersMiddleware:
+    """Convert OAuth2 Proxy HTTP headers to WSGI environment variables for Keystone federation.
+
+    Keystone federation expects OIDC claims as environment variables
+    (HTTP_OIDC_ISS, REMOTE_USER, etc.) set by Apache mod_auth_openidc.
+    OAuth2-Proxy provides these as HTTP headers instead. This middleware
+    decodes the JWT access token and maps claims to the expected
+    environment variables for federation endpoints only.
+    """
+
+    def __init__(self, application):
+        self.application = application
+
+    def __call__(self, environ, start_response):
+        path = environ.get('PATH_INFO', '')
+
+        if 'OS-FEDERATION' in path:
+            self._process_federation_request(environ)
+
+        return self.application(environ, start_response)
+
+    def _process_federation_request(self, environ):
+        """Extract OIDC claims from JWT and set env vars."""
+        LOG.debug("Processing federation request: %s",
+                  environ.get('PATH_INFO', ''))
+        token = self._extract_token(environ)
+
+        if token:
+            self._decode_and_set_claims(token, environ)
+        else:
+            LOG.warning("No JWT token found in federation request")
+
+        self._set_remote_user(environ)
+
+        if 'HTTP_OIDC_ISS' not in environ:
+            LOG.warning("HTTP_OIDC_ISS not set after processing")
+
+    def _extract_token(self, environ):
+        """Get JWT from X-Forwarded-Access-Token or Authorization."""
+        if 'HTTP_X_FORWARDED_ACCESS_TOKEN' in environ:
+            return environ['HTTP_X_FORWARDED_ACCESS_TOKEN']
+        if 'HTTP_AUTHORIZATION' in environ:
+            auth = environ['HTTP_AUTHORIZATION']
+            if auth.startswith('Bearer '):
+                return auth[7:]
+        return None
+
+    def _decode_and_set_claims(self, token, environ):
+        """Decode JWT and map claims to HTTP_OIDC_* env vars."""
+        try:
+            decoded = jwt.decode(token, options={
+                "verify_signature": False,
+                "verify_aud": False,
+                "verify_exp": False,
+            })
+            claim_map = {
+                'iss': 'HTTP_OIDC_ISS',
+                'sub': 'HTTP_OIDC_SUB',
+                'email': 'HTTP_OIDC_EMAIL',
+                'name': 'HTTP_OIDC_NAME',
+                'preferred_username': 'HTTP_OIDC_PREFERRED_USERNAME',
+            }
+            for claim, env_var in claim_map.items():
+                if claim in decoded:
+                    environ[env_var] = decoded[claim]
+        except Exception as e:
+            LOG.error("Failed to decode JWT token: %s", e)
+
+    def _set_remote_user(self, environ):
+        """Set REMOTE_USER with fallback chain."""
+        for source in ('HTTP_X_FORWARDED_USER',
+                       'HTTP_OIDC_EMAIL',
+                       'HTTP_OIDC_SUB'):
+            if source in environ:
+                environ['REMOTE_USER'] = environ[source]
+                LOG.debug("Set REMOTE_USER from %s", source)
+                return
+        LOG.warning("REMOTE_USER could not be set")
+
+
+def filter_factory(global_conf, **local_conf):
+    """PasteDeploy filter factory."""
+    def _filter(app):
+        return OAuth2ProxyHeadersMiddleware(app)
+    return _filter
