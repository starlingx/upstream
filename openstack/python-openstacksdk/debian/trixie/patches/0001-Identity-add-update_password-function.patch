@@ -385,6 +385,14 @@ class TestIdentityProxyUser(TestIdentityProxyBase):
     def test_user_update(self):
         self.verify_update(self.proxy.update_user, user.User)
 
+    def test_user_update_password(self):
+        self._verify(
