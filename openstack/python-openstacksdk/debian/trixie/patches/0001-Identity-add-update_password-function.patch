+
 
 class TestIdentityProxyTrust(TestIdentityProxyBase):
     def test_trust_create_attrs(self):
diff --git a/openstack/tests/unit/identity/v3/test_user.py b/openstack/tests/unit/identity/v3/test_user.py
index 070279d..ee72b05 100644
--- a/openstack/tests/unit/identity/v3/test_user.py
+++ b/openstack/tests/unit/identity/v3/test_user.py
@@ -10,6 +10,10 @@
 # License for the specific language governing permissions and limitations
